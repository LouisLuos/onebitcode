<!DOCTYPE html>
<html lang="en" data-bs-theme="dark" class="h-100">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>B-productive</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="d-flex flex-column h-100 bg-dark text-light">
    
    <%- include('partials/header') %>
    
    <main class="container flex-shrink-0 py-5">
        <h2 class="text-center mb-4">Lista de tarefas</h2>
        
        <div class="row justify-content-center mb-5">
            <div class="col-md-6">
                <form action="/lista/criar" method="POST" class="d-flex gap-2">
                    <input type="text" name="titulo" class="form-control bg-dark text-light border-secondary" placeholder="Nome da nova lista (ex: Estudos)" required>
                    <button type="submit" class="btn btn-primary shadow-sm">Criar</button>
                </form>
            </div>
        </div>

        <div class="row g-4">
            <% listas.forEach(lista => { %>
                <div class="col-md-4">
                    <div class="card bg-dark text-light h-100 shadow border border-secondary rounded-3">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold"><%= lista.titulo %></h5>
                            <p class="card-text text-secondary"><%= lista.tarefas.length %> tarefas registradas.</p>
                            <a href="/lista/<%= lista.id %>" class="btn btn-outline-light mt-auto">Abrir Lista</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </main>
    
    <%- include('partials/footer') %>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>