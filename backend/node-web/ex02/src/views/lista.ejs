<!DOCTYPE html>
<html lang="en" class="h-100">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= lista.titulo %> - B-productive</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="d-flex flex-column h-100 bg-dark text-light">
    
    <%- include('partials/header') %>

    <main class="flex-shrink-0">
        <div class="container py-5">
            <div class="text-center mb-4">
                <a href="/" class="btn btn-sm btn-outline-secondary mb-3">← Voltas as listas</a>
                <h2 class="display-5 fw-bold"><%= lista.titulo %></h2>
            </div>
            
            <div class="row justify-content-center mb-5">
                <div class="col-md-8">
                    <form action="/lista/<%= lista.id %>/adicionar" method="POST" class="d-flex gap-2">
                        <input 
                            type="text" 
                            name="tarefa" 
                            class="form-control bg-dark text-light border-secondary" 
                            placeholder="Digite uma nova tarefa..." 
                            required
                        >
                        <button type="submit" class="btn btn-primary shadow">Adicionar</button>
                    </form>
                </div>
            </div>

            <div class="row justify-content-center">
                <div class="col-md-8">
                    <div class="list-group shadow">
                        <% if (lista.tarefas.length > 0) { %>
                            <% lista.tarefas.forEach((tarefa, index) => { %>
                                <div class="list-group-item bg-secondary text-light border-dark mb-2 rounded d-flex justify-content-between align-items-center">
                                    <span><%= tarefa.texto %></span>
                                    
                                    <form action="/alterar-status" method="POST" class="m-0">
                                        <input type="hidden" name="listaId" value="<%= lista.id %>">
                                        <input type="hidden" name="tarefaIndex" value="<%= index %>">
                                        <button type="submit" class="btn btn-sm shadow-sm <%= tarefa.status === 'finalizada' ? 'btn-success' : 'btn-warning' %>">
                                            <%= tarefa.status === 'finalizada' ? 'Finalizada' : 'Pendente' %>
                                        </button>
                                    </form>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p class="text-center text-secondary">Nenhuma tarefa encontrada.</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>